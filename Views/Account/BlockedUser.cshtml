@{
    ViewData["Title"] = "Account Blocked";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 80%;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .pageSetup {
            min-height: calc(100vh - 70px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .blocked-container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                
            width: 100%;
            max-width: 560px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 40px;
            padding: 30px;
        }

        .icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            color: #212529;
            margin-bottom: 12px;
        }

        p {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 24px;
            text-align: center;
        }

        .btn-primary {
            background: #667eea;
            border: none;
            padding: 10px 32px;
            border-radius: 6px;
            font-weight: 500;
        }

        .btn-primary:hover {
            background: #5568d3;
        }
    </style>
</head>
<body>
    <main>
      <div class="pageSetup"> 
            <div class="blocked-container">
                <div class="icon">🚫</div>
                <h1>Account Blocked</h1>
                <p>
                    Your account has been blocked by an administrator and you cannot access this service at this time.
                </p>
                <p>
                    If you believe this is a mistake, please contact support.
                </p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Go Home</a>
            </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

