@model Inventory_Management_System.Models.ViewModels.UserProfileViewModel
@{
    var displayName = Model?.GetFullName();
    ViewData["Title"] = "Profile - " + (!string.IsNullOrEmpty(displayName) ? displayName : Model?.UserName ?? "");

    var ownedInventories = ViewBag.OwnedInventories as List<Inventory_Management_System.Models.Inventory>
                          ?? new List<Inventory_Management_System.Models.Inventory>();
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Profile</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Dashboard/Index" class="btn btn-secondary">← Back to Dashboard</a>
        </div>
    </div>

    <div class="row">
        <!-- Profile Card -->
        <div class="col-md-4">
            <div class="card mb-4 text-center">
                <div class="card-body">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
                        {
                            <img src="@Model.ProfilePictureUrl" alt="Avatar" class="rounded-circle" style="width:100px;height:100px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center"
                                 style="width:100px;height:100px;font-size:40px;">
                                👤
                            </div>
                        }
                    </div>

                    <h5 class="card-title">@(!string.IsNullOrWhiteSpace(Model?.GetFullName()) ? Model.GetFullName() : Model?.UserName)</h5>
                    <p class="text-muted mb-1">@Model?.Email</p>

                    <div class="mb-3">
                        @if (Model?.Roles != null && Model.Roles.Count > 0)
                        {
                            @foreach (var role in Model.Roles)
                            {
                                <span class="badge bg-secondary me-1 mb-1">@role</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                    </div>

                    <div>
                        @if (Model?.IsBlocked == true)
                        {
                            <span class="badge bg-warning text-dark">🔒 Blocked</span>
                        }
                        else
                        {
                            <span class="badge bg-success">✓ Active</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Account Info</h6>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Username</dt>
                        <dd class="col-sm-6">@Model?.UserName</dd>

                        <dt class="col-sm-6">Email</dt>
                        <dd class="col-sm-6">@Model?.Email</dd>

                        <dt class="col-sm-6">Provider</dt>
                        <dd class="col-sm-6">@(!string.IsNullOrEmpty(Model?.Provider) ? Model.Provider : "Email")</dd>

                        <dt class="col-sm-6">Joined</dt>
                        <dd class="col-sm-6">@Model?.CreatedAt.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-sm-6">Last Login</dt>
                        <dd class="col-sm-6">
                            @if (Model?.LastLoginAt.HasValue == true)
                            {
                                @Model.LastLoginAt.Value.ToString("MMM dd, yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">Never</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Additional read-only details -->
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">About</h6>
                </div>
                <div class="card-body">
                    <!-- Owned Inventories Section -->
                    <div class="mb-5">
                        <h2 class="mb-3">My Inventories <span class="badge bg-primary">@ownedInventories.Count</span></h2>

                        @if (!ownedInventories.Any())
                        {
                            <div class="card">
                                <div class="card-body empty-state">
                                    <p class="text-muted">No inventories created yet</p>
                                    <a href="/Inventories/Create" class="btn btn-primary">Create Your First Inventory</a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Bulk Actions Toolbar for My Inventories -->
                            <div class="card mb-3" id="ownedToolbar" style="display: none; background-color: #f0f7ff; border-left: 4px solid #0d6efd;">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <span id="ownedSelectedCount" style="font-weight: 600; color: #0d6efd;"></span>
                                    </div>
                                    <div class="btn-group gap-2" role="group">
                                        <a href="#" class="btn btn-sm btn-info" id="ownedViewBtn">👁️ View</a>
                                        <a href="#" class="btn btn-sm btn-secondary" id="ownedEditBtn">✏️ Edit</a>
                                        <a href="#" class="btn btn-sm btn-warning" id="ownedSettingsBtn">⚙️ Settings</a>
                                    </div>
                                </div>
                            </div>

                            <div class="table-responsive-custom">
                                <table class="table table-hover mb-0" id="ownedTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 3%">
                                                <input type="checkbox" id="ownedSelectAllCheckbox" class="form-check-input" onchange="toggleSelectAll(this, 'owned')" style="display: none;">
                                            </th>
                                            <th>Title</th>
                                            <th>Items</th>
                                            <th>Visibility</th>
                                            <th>Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var inventory in ownedInventories)
                                        {
                                            <tr>
                                                <td>
                                                    <input type="checkbox" class="form-check-input owned-checkbox" value="@inventory.Id" onchange="updateOwnedToolbar()">
                                                </td>
                                                <td>
                                                    <strong>@inventory.Title</strong>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">@inventory.Items.Count items</span>
                                                </td>
                                                <td>
                                                    @if (inventory.Visibility == Inventory_Management_System.Models.VisibilityType.Public)
                                                    {
                                                        <span class="badge bg-success">Public</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning">Private</span>
                                                    }
                                                </td>
                                                <td>
                                                    <small>@inventory.CreatedAt.ToString("MMM dd, yyyy")</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination for Owned Inventories -->
                            @if (ViewBag.OwnedTotalPages > 1)
                            {
                                <nav class="mt-3">
                                    <ul class="pagination justify-content-center">
                                        <li class="page-item @(ViewBag.OwnedCurrentPage == 1 ? "disabled" : "")">
                                            <a class="page-link" href="?ownedPage=1&accessiblePage=@ViewBag.AccessibleCurrentPage&sortBy=@ViewBag.CurrentSort">First</a>
                                        </li>
                                        <li class="page-item @(ViewBag.OwnedCurrentPage == 1 ? "disabled" : "")">
                                            <a class="page-link" href="?ownedPage=@(ViewBag.OwnedCurrentPage - 1)&accessiblePage=@ViewBag.AccessibleCurrentPage&sortBy=@ViewBag.CurrentSort">Previous</a>
                                        </li>

                                        @for (int i = 1; i <= ViewBag.OwnedTotalPages; i++)
                                        {
                                            if (i == ViewBag.OwnedCurrentPage)
                                            {
                                                <li class="page-item active">
                                                    <span class="page-link">@i</span>
                                                </li>
                                            }
                                            else if (i <= 3 || i >= ViewBag.OwnedTotalPages - 2 || (i >= ViewBag.OwnedCurrentPage - 2 && i <= ViewBag.OwnedCurrentPage + 2))
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" href="?ownedPage=@i&accessiblePage=@ViewBag.AccessibleCurrentPage&sortBy=@ViewBag.CurrentSort">@i</a>
                                                </li>
                                            }
                                            else if (i == 4 || i == ViewBag.OwnedTotalPages - 3)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                        }

                                        <li class="page-item @(ViewBag.OwnedCurrentPage == ViewBag.OwnedTotalPages ? "disabled" : "")">
                                            <a class="page-link" href="?ownedPage=@(ViewBag.OwnedCurrentPage + 1)&accessiblePage=@ViewBag.AccessibleCurrentPage&sortBy=@ViewBag.CurrentSort">Next</a>
                                        </li>
                                        <li class="page-item @(ViewBag.OwnedCurrentPage == ViewBag.OwnedTotalPages ? "disabled" : "")">
                                            <a class="page-link" href="?ownedPage=@ViewBag.OwnedTotalPages&accessiblePage=@ViewBag.AccessibleCurrentPage&sortBy=@ViewBag.CurrentSort">Last</a>
                                        </li>
                                    </ul>
                                </nav>

                                <div class="alert alert-info mt-2">
                                    <strong>Total:</strong> @ViewBag.OwnedTotalCount inventories |
                                    <strong>Page:</strong> @ViewBag.OwnedCurrentPage of @ViewBag.OwnedTotalPages |
                                    <strong>Per Page:</strong> @ViewBag.OwnedPageSize
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-monospace {
        font-family: 'Courier New', monospace;
    }

</style>

<script>
    function updateOwnedToolbar() {
        const checkboxes = document.querySelectorAll('.owned-checkbox:checked');
        const toolbar = document.getElementById('ownedToolbar');
        const selectedCount = document.getElementById('ownedSelectedCount');

        if (checkboxes.length > 0) {
            toolbar.style.display = 'block';
            selectedCount.textContent = `1 inventory selected`;
            updateOwnedActionButtons();
        } else {
            toolbar.style.display = 'none';
        }
    }

    function updateOwnedActionButtons() {
        const checkbox = document.querySelector('.owned-checkbox:checked');
        if (!checkbox) return;

        const inventoryId = checkbox.value;
        const viewBtn = document.getElementById('ownedViewBtn');
        const editBtn = document.getElementById('ownedEditBtn');
        const settingsBtn = document.getElementById('ownedSettingsBtn');

        viewBtn.href = `/Inventories/Details/${inventoryId}`;
        editBtn.href = `/Inventories/Edit/${inventoryId}`;
        settingsBtn.href = `/Inventories/Settings/${inventoryId}`;
    }

    function toggleSelectAll(checkbox, section) {
        checkbox.checked = false;
    }

    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('owned-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.owned-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateOwnedToolbar();
        }
    });

function updateAccessibleActionButtons() {
        const checkbox = document.querySelector('.accessible-checkbox:checked');
        if (!checkbox) return;

        const inventoryId = checkbox.value;
        const viewBtn = document.getElementById('accessibleViewBtn');

        viewBtn.href = `/Inventories/Details/${inventoryId}`;
    }

    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('accessible-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.accessible-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateAccessibleToolbar();
        }
    });
</script>


