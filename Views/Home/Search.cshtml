@using Inventory_Management_System.Models.ViewModels
@model SearchResultsViewModel

@{
    ViewData["Title"] = $"Search Results for '{Model.Query}' - Inventory Manager";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <h1>Search Results</h1>
            <p class="text-muted">
                Found <strong>@Model.Results.Count</strong> result(s) for "<strong>@Model.Query</strong>"
            </p>

            <form asp-action="Search" method="get" class="input-group input-group-lg mb-4" id="searchPageForm">
                <input 
                    type="text" 
                    name="query" 
                    value="@Model.Query"
                    class="form-control" 
                    placeholder="Search again..."
                    required
                    minlength="1"
                    pattern=".*\S.*">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
            </form>
        </div>
    </div>

<div class="row">
        <div class="col-md-8 mx-auto">
            @if (Model.Results.Any())
            {
                <div class="list-group">
                    @foreach (var inventory in Model.Results)
                    {
                        <div class="list-group-item" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Details", "Inventories", new { id = inventory.Id })'">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(inventory.ImageUrl))
                                    {
                                        <img src="@inventory.ImageUrl" alt="@inventory.Title" 
                                             style="max-width: 100%; height: auto; max-height: 80px;" class="rounded">
                                    }
                                </div>
                                <div class="col-md-8">
                                    <h5 class="mb-1">
                                        @inventory.Title
                                    </h5>
                                    <p class="text-muted mb-2">@inventory.Description</p>
                                    <div>
                                        <small class="text-muted">
                                            By <strong>@inventory.OwnerName</strong> 
                                            ¢ @inventory.CreatedAt.ToString("MMM dd, yyyy")
                                            ¢ @inventory.ItemCount items
                                        </small>
                                    </div>
                                    <div class="mt-2">
                                        @foreach (var tag in inventory.Tags)
                                        {
                                            <a asp-action="FilterByTag" asp-route-tag="@tag" 
                                               class="badge bg-secondary text-decoration-none">
                                                @tag
                                            </a>
                                        }
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                <nav class="mt-4">
                    <ul class="pagination">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Search" asp-route-query="@Model.Query" 
                                   asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                            </li>
                        }

                        <li class="page-item active">
                            <span class="page-link">Page @Model.CurrentPage</span>
                        </li>

                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Search" asp-route-query="@Model.Query" 
                                   asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
            else
            {
                <div class="alert alert-warning">
                    No results found for "<strong>@Model.Query</strong>". Try different keywords!
                </div>
            }
        </div>
    </div>
</div>

<script>
    document.getElementById('searchPageForm').addEventListener('submit', function (e) {
        const searchInput = this.querySelector('input[name="query"]').value.trim();
            
        if (!searchInput) {
            e.preventDefault();
            alert('Please enter a search query');
            return false;
        }
    });
</script>

