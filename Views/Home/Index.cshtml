@using Inventory_Management_System.Models.ViewModels
@model HomePageViewModel

@{
    ViewData["Title"] = "Inventory Manager";
}
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/premium-login.css" />
</head>
<!-- Centered Branding -->
<div class="branding-section">
    <div class="branding-icon">📦</div>
    <h2>Inventory Manager</h2>
    <p>Organize, track, and manage your collections with ease</p>
</div>

<div class="container-fluid py-5">
    <!-- Search Bar -->
    <div class="row mb-5">
        <div class="col-md-8 mx-auto">
            <form asp-action="Search" method="get" class="input-group input-group-lg">
                <input 
                    type="text" 
                    name="query" 
                    class="form-control" 
                    placeholder="Search inventories by name, description, or tags..."
                    aria-label="Search inventories">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
            </form>
        </div>
    </div>

    <!-- Latest Inventories Section -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-clock-history"></i> Latest Inventories
            </h2>
            
            @if (Model?.LatestInventories?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Image</th>
                                <th>Creator</th>
                                <th>Items</th>
                                <th>Tags</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inventory in Model.LatestInventories)
                            {
                                <tr>
                                    <td class="fw-bold">@inventory.Title</td>
                                    <td>@inventory.Description</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(inventory.ImageUrl))
                                        {
                                            <img src="@inventory.ImageUrl" alt="@inventory.Title" 
                                                 style="max-width: 60px; max-height: 60px;" class="rounded">
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No Image</span>
                                        }
                                    </td>
                                    <td>@inventory.OwnerName</td>
                                    <td><span class="badge bg-info">@inventory.ItemCount items</span></td>
                                    <td>
                                        @foreach (var tag in inventory.Tags)
                                        {
                                            <a asp-action="FilterByTag" asp-route-tag="@tag" 
                                               class="badge bg-secondary text-decoration-none me-1">
                                                @tag
                                            </a>
                                        }
                                    </td>
                                    <td class="text-muted small">@inventory.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No public inventories yet. Create one or wait for others to share!
                </div>
            }
        </div>
    </div>

    <!-- Top 5 Popular Inventories -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-fire"></i> Top 5 Most Popular Inventories
            </h2>
            
            @if (Model?.TopPopularInventories?.Any() == true)
            {
                <div class="row">
                    @foreach (var inventory in Model.TopPopularInventories)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm hover-card">
                                @if (!string.IsNullOrEmpty(inventory.ImageUrl))
                                {
                                    <img src="@inventory.ImageUrl" class="card-img-top" 
                                         alt="@inventory.Title" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" 
                                         style="height: 200px;">
                                        <i class="bi bi-image" style="font-size: 3rem; color: #ccc;"></i>
                                    </div>
                                }
                                <div class="card-body">
                                    <h5 class="card-title">@inventory.Title</h5>
                                    <p class="card-text text-muted small">@inventory.Description</p>
                                    <div class="mb-2">
                                        <small class="text-muted">By <strong>@inventory.OwnerName</strong></small>
                                    </div>
                                    <div class="mb-2">
                                        <span class="badge bg-success">@inventory.ItemCount Items</span>
                                    </div>
                                    <div class="mb-3">
                                        @foreach (var tag in inventory.Tags)
                                        {
                                            <a asp-action="FilterByTag" asp-route-tag="@tag" 
                                               class="badge bg-light text-dark text-decoration-none me-1">
                                                #@tag
                                            </a>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer bg-white border-top-0">
                                    <a asp-controller="Inventories" asp-action="Details" 
                                       asp-route-id="@inventory.Id" class="btn btn-primary btn-sm w-100">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No inventories with items yet.
                </div>
            }
        </div>
    </div>

    <!-- Tag Cloud -->
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-tags"></i> Popular Tags
            </h2>
            
            @if (Model?.TagCloud?.Any() == true)
            {
                <div class="tag-cloud bg-light p-4 rounded">
                    @foreach (var tag in Model.TagCloud)
                    {
                        var sizeClass = tag.Size switch
                        {
                            "ExtraLarge" => "tag-xl",
                            "Large" => "tag-lg",
                            "Medium" => "tag-md",
                            _ => "tag-sm"
                        };
                        
                        <a asp-action="FilterByTag" asp-route-tag="@tag.TagName" 
                           class="tag @sizeClass text-decoration-none me-2 mb-2" 
                           title="@tag.Frequency inventories">
                            @tag.TagName <span class="badge bg-secondary ms-1">@tag.Frequency</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No tags available yet.
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15) !important;
    }
    
    .tag-cloud {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
    }
    
    .tag {
        display: inline-block;
        padding: 6px 12px;
        background-color: #e9ecef;
        border-radius: 20px;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .tag:hover {
        background-color: #0d6efd;
        color: white !important;
    }
    
    .tag-sm { font-size: 0.9rem; }
    .tag-md { font-size: 1.1rem; }
    .tag-lg { font-size: 1.3rem; font-weight: 600; }
    .tag-xl { font-size: 1.5rem; font-weight: 700; }
</style>
