@* Language Switcher Component *@
<div class="language-switcher ms-2">
    <div class="btn-group" role="group" title="Select language">
        <button id="languageToggleEn" 
                type="button" 
                class="btn btn-sm btn-outline-secondary" 
                data-language="en"
                data-bs-toggle="tooltip"
                data-bs-title="English">
            🇬🇧 EN
        </button>
        <button id="languageToggleEs" 
                type="button" 
                class="btn btn-sm btn-outline-secondary" 
                data-language="es"
                data-bs-toggle="tooltip"
                data-bs-title="Español">
            🇪🇸 ES
        </button>
    </div>
</div>

<style>
    .language-switcher .btn {
        transition: all 0.3s ease;
        font-size: 0.85rem;
        padding: 0.375rem 0.75rem;
    }

    .language-switcher .btn:hover {
        background-color: var(--bg-hover);
    }

    .language-switcher .btn.active {
        background-color: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .btn-group > .btn:not(:last-child):not(.dropdown-toggle) {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    .btn-group > .btn:not(:first-child),
    .btn-group > .dropdown-toggle:nth-child(n+3),
    .btn-group > :not(.btn-check) + .btn {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }
</style>
