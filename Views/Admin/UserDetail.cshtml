@using Inventory_Management_System.Models.ViewModels
@model UserAdminViewModel
@{
    ViewData["Title"] = $"User: {Model.FirstName} {Model.LastName}";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>👤 User Details</h1>
            <p class="text-muted">Manage this user's account and permissions</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Admin/Users" class="btn btn-secondary">← Back to Users</a>
        </div>
    </div>

    <div class="row">
        <!-- User Card -->
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" 
                             style="width: 80px; height: 80px; font-size: 40px;">
                            👤
                        </div>
                    </div>
                    <h5 class="card-title">@Model.FirstName @Model.LastName</h5>
                    <p class="text-muted">@Model.Email</p>

                    <div class="mb-3">
                        @if (Model.IsAdmin)
                        {
                            <span class="badge bg-danger">⭐ Administrator</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">👤 Regular User</span>
                        }
                    </div>

                    <div>
                        @if (Model.IsBlocked)
                        {
                            <span class="badge bg-warning text-dark d-block mb-2">🔒 BLOCKED</span>
                        }
                        else
                        {
                            <span class="badge bg-success d-block mb-2">✓ ACTIVE</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Account Info Card -->
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Account Information</h6>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Created:</dt>
                        <dd class="col-sm-6">
                            <small>@Model.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </dd>

                        <dt class="col-sm-6">Last Login:</dt>
                        <dd class="col-sm-6">
                            <small>
                                @if (Model.LastLoginAt.HasValue)
                                {
                                    @Model.LastLoginAt.Value.ToString("MMM dd, yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">Never</span>
                                }
                            </small>
                        </dd>

                        <dt class="col-sm-6">Provider:</dt>
                        <dd class="col-sm-6">
                            <small>@(Model.Provider ?? "Email")</small>
                        </dd>

                        <dt class="col-sm-6">Username:</dt>
                        <dd class="col-sm-6">
                            <small class="text-monospace">@Model.UserName</small>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Actions</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Block/Unblock -->
                        <div class="col-md-6">
                            <div class="card border">
                                <div class="card-body">
                                    <h6 class="card-title">🔒 Access Control</h6>
                                    <p class="text-muted small mb-3">
                                        @if (Model.IsBlocked)
                                        {
                                            @("This user is currently blocked and cannot log in.")
                                        }
                                        else
                                        {
                                            @("This user can currently log in.")
                                        }
                                    </p>
                                    @if (Model.IsBlocked)
                                    {
                                        <form action="/Admin/Users/@Model.Id/Unblock" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm w-100">
                                                🔓 Unblock User
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form action="/Admin/Users/@Model.Id/Block" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-warning btn-sm w-100"
                                                    onclick="return confirm('Block this user from logging in?');">
                                                🔒 Block User
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Admin Role -->
                        <div class="col-md-6">
                            <div class="card border">
                                <div class="card-body">
                                    <h6 class="card-title">⭐ Admin Privileges</h6>
                                    <p class="text-muted small mb-3">
                                        @if (Model.IsAdmin)
                                        {
                                            @("This user has admin privileges.")
                                        }
                                        else
                                        {
                                            @("This user is a regular user.")
                                        }
                                    </p>
                                    @if (Model.IsAdmin)
                                    {
                                        <form action="/Admin/Users/@Model.Id/RevokeAdmin" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-info btn-sm w-100"
                                                    onclick="return confirm('Revoke admin role from this user?');">
                                                ⬇️ Revoke Admin Role
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form action="/Admin/Users/@Model.Id/GrantAdmin" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm w-100"
                                                    onclick="return confirm('Grant admin role to this user?');">
                                                ⬆️ Grant Admin Role
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Delete User -->
                        <div class="col-md-12">
                            <div class="card border border-danger">
                                <div class="card-body">
                                    <h6 class="card-title text-danger">🗑️ Danger Zone</h6>
                                    <p class="text-muted small mb-3">
                                        Permanently delete this user and all associated data. This action cannot be undone.
                                    </p>
                                    <form action="/Admin/Users/@Model.Id/Delete" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('PERMANENTLY DELETE this user? This cannot be undone. All inventories and items will be deleted.');">
                                            🗑️ Delete User Permanently
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Roles Card -->
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Current Roles</h6>
                </div>
                <div class="card-body">
                    @if (Model.Roles.Count == 0)
                    {
                        <p class="text-muted mb-0">No roles assigned</p>
                    }
                    else
                    {
                        @foreach (var role in Model.Roles)
                        {
                            @if (role == "Admin")
                            {
                                <span class="badge bg-danger me-2 mb-2">⭐ @role</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary me-2 mb-2">@role</span>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-monospace {
        font-family: 'Courier New', monospace;
    }

    .card.border {
        border: 1px solid #dee2e6;
    }

    .card.border-danger {
        border: 2px solid #dc3545 !important;
    }
</style>