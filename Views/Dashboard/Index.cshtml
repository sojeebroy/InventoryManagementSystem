@{
    ViewData["Title"] = "Dashboard";
    var ownedInventories = (List<Inventory>)ViewBag.OwnedInventories;
    var accessibleInventories = (List<Inventory>)ViewBag.AccessibleInventories;
}

<div class="container-main">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>My Dashboard</h1>
            <p class="text-muted">Manage your inventories and items</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Inventories/Create" class="btn btn-primary">+ Create New Inventory</a>
        </div>
    </div>

    <!-- Owned Inventories Section -->
    <div class="mb-5">
        <h2 class="mb-3">My Inventories <span class="badge bg-primary">@ownedInventories.Count</span></h2>

        @if (!ownedInventories.Any())
        {
            <div class="card">
                <div class="card-body empty-state">
                    <p class="text-muted">No inventories created yet</p>
                    <a href="/Inventories/Create" class="btn btn-primary">Create Your First Inventory</a>
                </div>
            </div>
        }
        else
        {
            <!-- Bulk Actions Toolbar for My Inventories -->
            <div class="card mb-3" id="ownedToolbar" style="display: none; background-color: #f0f7ff; border-left: 4px solid #0d6efd;">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <span id="ownedSelectedCount" style="font-weight: 600; color: #0d6efd;"></span>
                    </div>
                    <div class="btn-group gap-2" role="group">
                        <a href="#" class="btn btn-sm btn-info" id="ownedViewBtn">👁️ View</a>
                        <a href="#" class="btn btn-sm btn-secondary" id="ownedEditBtn">✏️ Edit</a>
                        <a href="#" class="btn btn-sm btn-warning" id="ownedSettingsBtn">⚙️ Settings</a>
                    </div>
                </div>
            </div>

            <div class="table-responsive-custom">
                <table class="table table-hover mb-0" id="ownedTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 3%">
                                <input type="checkbox" id="ownedSelectAllCheckbox" class="form-check-input" onchange="toggleSelectAll(this, 'owned')" style="display: none;">
                            </th>
                            <th>Title</th>
                            <th>Items</th>
                            <th>Visibility</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inventory in ownedInventories)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input owned-checkbox" value="@inventory.Id" onchange="updateOwnedToolbar()">
                                </td>
                                <td>
                                    <strong>@inventory.Title</strong>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@inventory.Items.Count items</span>
                                </td>
                                <td>
                                    @if (inventory.Visibility == Inventory_Management_System.Models.VisibilityType.Public)
                                    {
                                        <span class="badge bg-success">Public</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Private</span>
                                    }
                                </td>
                                <td>
                                    <small>@inventory.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td class="text-end">
                                    <a href="/Inventories/Details/@inventory.Id" class="btn btn-sm btn-outline-primary">View</a>
                                    <a href="/Inventories/Edit/@inventory.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a href="/Inventories/Settings/@inventory.Id" class="btn btn-sm btn-outline-info">Settings</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Accessible Inventories Section -->
    <div>
        <h2 class="mb-3">Inventories I Can Access <span class="badge bg-info">@accessibleInventories.Count</span></h2>

        @if (!accessibleInventories.Any())
        {
            <div class="card">
                <div class="card-body empty-state">
                    <p class="text-muted">No shared inventories yet</p>
                </div>
            </div>
        }
        else
        {
            <!-- Bulk Actions Toolbar for Accessible Inventories -->
            <div class="card mb-3" id="accessibleToolbar" style="display: none; background-color: #f0f7ff; border-left: 4px solid #0d6efd;">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <span id="accessibleSelectedCount" style="font-weight: 600; color: #0d6efd;"></span>
                    </div>
                    <div class="btn-group gap-2" role="group">
                        <a href="#" class="btn btn-sm btn-info" id="accessibleViewBtn">👁️ View</a>
                    </div>
                </div>
            </div>

            <div class="table-responsive-custom">
                <table class="table table-hover mb-0" id="accessibleTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 3%">
                                <input type="checkbox" id="accessibleSelectAllCheckbox" class="form-check-input" onchange="toggleSelectAll(this, 'accessible')" style="display: none;">
                            </th>
                            <th>Title</th>
                            <th>Owner</th>
                            <th>Items</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inventory in accessibleInventories)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input accessible-checkbox" value="@inventory.Id" onchange="updateAccessibleToolbar()">
                                </td>
                                <td>
                                    <strong>@inventory.Title</strong>
                                </td>
                                <td>
                                    <small>@inventory.Owner?.UserName</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@inventory.Items.Count items</span>
                                </td>
                                <td>
                                    <small>@inventory.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td class="text-end">
                                    <a href="/Inventories/Details/@inventory.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .form-check-input {
        cursor: pointer;
    }

    .gap-2 {
        gap: 0.5rem;
    }

    .btn-group {
        display: flex;
    }
</style>

<script>
    // ===== OWNED INVENTORIES FUNCTIONS =====
    function updateOwnedToolbar() {
        const checkboxes = document.querySelectorAll('.owned-checkbox:checked');
        const toolbar = document.getElementById('ownedToolbar');
        const selectedCount = document.getElementById('ownedSelectedCount');

        if (checkboxes.length > 0) {
            toolbar.style.display = 'block';
            selectedCount.textContent = `1 inventory selected`;
            updateOwnedActionButtons();
        } else {
            toolbar.style.display = 'none';
        }
    }

    function updateOwnedActionButtons() {
        const checkbox = document.querySelector('.owned-checkbox:checked');
        if (!checkbox) return;

        const inventoryId = checkbox.value;
        const viewBtn = document.getElementById('ownedViewBtn');
        const editBtn = document.getElementById('ownedEditBtn');
        const settingsBtn = document.getElementById('ownedSettingsBtn');

        viewBtn.href = `/Inventories/Details/${inventoryId}`;
        editBtn.href = `/Inventories/Edit/${inventoryId}`;
        settingsBtn.href = `/Inventories/Settings/${inventoryId}`;
    }

    function toggleSelectAll(checkbox, section) {
        checkbox.checked = false;
    }

    // Handle owned checkbox changes - only allow single selection
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('owned-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.owned-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateOwnedToolbar();
        }
    });

    // ===== ACCESSIBLE INVENTORIES FUNCTIONS =====
    function updateAccessibleToolbar() {
        const checkboxes = document.querySelectorAll('.accessible-checkbox:checked');
        const toolbar = document.getElementById('accessibleToolbar');
        const selectedCount = document.getElementById('accessibleSelectedCount');

        if (checkboxes.length > 0) {
            toolbar.style.display = 'block';
            selectedCount.textContent = `1 inventory selected`;
            updateAccessibleActionButtons();
        } else {
            toolbar.style.display = 'none';
        }
    }

    function updateAccessibleActionButtons() {
        const checkbox = document.querySelector('.accessible-checkbox:checked');
        if (!checkbox) return;

        const inventoryId = checkbox.value;
        const viewBtn = document.getElementById('accessibleViewBtn');

        viewBtn.href = `/Inventories/Details/${inventoryId}`;
    }

    // Handle accessible checkbox changes - only allow single selection
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('accessible-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.accessible-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateAccessibleToolbar();
        }
    });
</script>
