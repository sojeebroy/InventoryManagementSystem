@model Inventory

<div class="row mb-4">
    <div class="col">
        <h5>Settings</h5>
        <p class="text-muted">Configure your inventory settings</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4" role="tablist" style="border-bottom: 2px solid #e9ecef;">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="custom-id-tab" data-bs-toggle="tab" data-bs-target="#custom-id" type="button" role="tab">
            Custom ID
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="fields-tab" data-bs-toggle="tab" data-bs-target="#fields" type="button" role="tab">
            Fields
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="access-tab" data-bs-toggle="tab" data-bs-target="#access" type="button" role="tab">
            Access
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="export-tab" data-bs-toggle="tab" data-bs-target="#export" type="button" role="tab">
            Export
        </button>
    </li>
</ul>

<div class="tab-content">
    <!-- Custom ID Configuration -->
    <div class="tab-pane fade show active" id="custom-id" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="card-title mb-2">Custom ID Configuration</h6>
                <p class="text-muted small mb-4">
                    You can set up items with inventory numbers in your preferred format.<br>
                    To create a format, add new elements, edit them, reorder, or drag elements out of the form to delete them.
                </p>

                <div class="mb-4 p-3 bg-light rounded">
                    <label class="text-muted small mb-2" style="display: block;">Example:</label>
                    <code id="idPreview" style="font-size: 18px; font-weight: 500;">🔐¯-A7E3A_013_2025</code>
                </div>

                <div id="idElementsContainer" class="mb-4">
                    <!-- Dynamic elements will be added here -->
                </div>

                <button type="button" class="btn btn-sm btn-outline-primary" id="addElementBtn">
                    <i class="bi bi-plus-lg"></i> Add element
                </button>
            </div>
        </div>
    </div>

    <!-- Fields Configuration -->
    <div class="tab-pane fade" id="fields" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="card-title mb-2">Custom Fields</h6>
                <p class="text-muted small mb-4">
                    You can add up to 3 fields of each type: Text, Multi-line Text, Numeric, Boolean, and Link.
                </p>

                <div id="fieldsContainer" class="mb-4">
                    @foreach (var field in Model.CustomFields.OrderBy(f => f.DisplayOrder))
                    {
                        <div class="card mb-2 field-item" data-field-id="@field.Id" style="background-color: #f8f9fa;">
                            <div class="card-body p-3">
                                <div class="row align-items-center">
                                    <div class="col">
                                        <h6 class="mb-1">@field.Title</h6>
                                        <p class="small text-muted mb-0">@field.FieldType - @(field.IsVisibleInTable ? "Visible" : "Hidden")</p>
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" class="btn btn-sm btn-outline-danger deleteFieldBtn" data-field-id="@field.Id">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="btn btn-sm btn-outline-primary" id="addFieldBtn">
                    <i class="bi bi-plus-lg"></i> Add field
                </button>
            </div>
        </div>
    </div>

    <!-- Access Control -->
    <div class="tab-pane fade" id="access" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="card-title mb-2">Access Settings</h6>
                <p class="text-muted small mb-4">
                    Control who can access and interact with this inventory.
                </p>

                <div class="mb-4">
                    <label class="form-label fw-500">Visibility</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="visibility" id="visibilityPublic" value="Public" checked="@(Model.Visibility == VisibilityType.Public)">
                        <label class="btn btn-outline-secondary" for="visibilityPublic">
                            <i class="bi bi-globe"></i> Public
                        </label>

                        <input type="radio" class="btn-check" name="visibility" id="visibilityPrivate" value="Private" checked="@(Model.Visibility == VisibilityType.Private)">
                        <label class="btn btn-outline-secondary" for="visibilityPrivate">
                            <i class="bi bi-lock"></i> Private
                        </label>
                    </div>
                </div>

                @if (Model.Visibility == VisibilityType.Private)
                {
                    <div class="mb-4">
                        <label class="form-label fw-500">Grant Access To</label>
                        <div class="input-group input-group-sm">
                            <input type="text" id="userSearchInput" class="form-control" placeholder="Search user by name or email...">
                            <button type="button" class="btn btn-outline-secondary" id="grantAccessBtn">Grant</button>
                        </div>
                        <small class="text-muted d-block mt-2">Start typing to search for users</small>
                    </div>

                    <div id="accessList">
                        <h6 class="mb-3">Current Access</h6>
                        <ul class="list-group list-group-sm">
                            @foreach (var access in Model.AccessControls)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-500">@access.User?.UserName</span>
                                        <br>
                                        <small class="text-muted">@access.User?.Email</small>
                                    </div>
                                    <div>
                                        <span class="badge bg-info">@access.AccessLevel</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <button type="button" class="btn btn-sm btn-primary mt-4" id="saveAccessBtn">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Export Tab -->
    <div class="tab-pane fade" id="export" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="card-title mb-4">Export Inventory</h6>
                <p class="text-muted mb-4">Download your inventory data in various formats.</p>

                <div class="row">
                    <div class="col-md-6">
                        <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-3">
                            <i class="bi bi-filetype-csv"></i> Export as CSV
                        </button>
                    </div>
                    <div class="col-md-6">
                        <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-3">
                            <i class="bi bi-filetype-json"></i> Export as JSON
                        </button>
                    </div>
                    <div class="col-md-6">
                        <button type="button" class="btn btn-sm btn-outline-secondary w-100">
                            <i class="bi bi-filetype-pdf"></i> Export as PDF
                        </button>
                    </div>
                    <div class="col-md-6">
                        <button type="button" class="btn btn-sm btn-outline-secondary w-100">
                            <i class="bi bi-filetype-xlsx"></i> Export as Excel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Field Modal -->
<div class="modal fade" id="addFieldModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Custom Field</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addFieldForm">
                    <div class="mb-3">
                        <label class="form-label">Field Name *</label>
                        <input type="text" class="form-control form-control-sm" id="fieldNameInput" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Field Type *</label>
                        <select class="form-select form-select-sm" id="fieldTypeSelect" required>
                            <option value="">Select type</option>
                            <option value="SingleLineText">Single Line Text</option>
                            <option value="MultiLineText">Multi-Line Text</option>
                            <option value="Numeric">Numeric</option>
                            <option value="Boolean">Boolean (Yes/No)</option>
                            <option value="Link">Link</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description (optional)</label>
                        <textarea class="form-control form-control-sm" id="fieldDescriptionInput" rows="2"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="fieldVisibleCheck" checked>
                        <label class="form-check-label" for="fieldVisibleCheck">
                            Visible in table
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="saveFieldBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<script>
    const inventoryId = @Model.Id;
    const addFieldModal = new bootstrap.Modal(document.getElementById('addFieldModal'));

    document.getElementById('addFieldBtn').addEventListener('click', () => {
        document.getElementById('addFieldForm').reset();
        addFieldModal.show();
    });

    document.getElementById('saveFieldBtn').addEventListener('click', async () => {
        const fieldName = document.getElementById('fieldNameInput').value;
        const fieldType = document.getElementById('fieldTypeSelect').value;
        const description = document.getElementById('fieldDescriptionInput').value;
        const isVisible = document.getElementById('fieldVisibleCheck').checked;

        if (!fieldName || !fieldType) {
            alert('Please fill in all required fields');
            return;
        }

        try {
            addFieldModal.hide();
            alert('Field will be added (API endpoint needed)');
        } catch (error) {
            console.error('Error:', error);
        }
    });

    document.getElementById('addElementBtn').addEventListener('click', () => {
        alert('Add ID element builder (implementation needed)');
    });

    document.querySelectorAll('.deleteFieldBtn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            if (confirm('Are you sure you want to delete this field?')) {
                const fieldId = e.target.dataset.fieldId;
                location.reload();
            }
        });
    });

    document.getElementById('saveAccessBtn').addEventListener('click', async () => {
        const visibility = document.getElementById('visibilityPublic').checked ? 'Public' : 'Private';
        alert('Access settings will be saved (API endpoint needed)');
    });
</script>


