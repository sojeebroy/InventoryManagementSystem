@model Inventory
@{
    ViewData["Title"] = Model.Title;
}

<div class="container-main">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@Model.Title</h1> @* [cite: 66] *@
            <p class="text-muted">
                Created by @Model.Owner?.UserName on @Model.CreatedAt.ToString("MMM dd, yyyy") @* [cite: 66] *@
            </p>
        </div>

        <div class="col-md-4 text-end">
            @* [cite: 67] *@
            <a href="/Home/Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Home</a>  @* [cite: 67] *@
            @if (ViewBag.CanEdit)
            {
                <a href="/Inventories/Edit/@Model.Id" class="btn btn-primary">Edit</a>
                <a href="/Inventories/Settings/@Model.Id" class="btn btn-warning">Settings</a>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mb-4">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="row mb-4">
                    <div class="col-md-12">
                        @* [cite: 69] *@
                        <img src="@Model.ImageUrl" class="img-fluid rounded" style="max-height: 300px; object-fit: cover;"> @* [cite: 69, 70] *@
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Information</h5> @* [cite: 71] *@
                    <dl class="row">
                        <dt class="col-sm-4">Category:</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Category</span></dd> @* [cite: 71] *@

                        <dt class="col-sm-4">Visibility:</dt> @* [cite: 72] *@
                        <dd class="col-sm-8">
                            @if (Model.Visibility == Inventory_Management_System.Models.VisibilityType.Public)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Private</span>
                            }
                        </dd> @* [cite: 75] *@

                        <dt class="col-sm-4">Tags:</dt>
                        <dd class="col-sm-8">
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="badge bg-info">@tag.Tag</span>
                            }
                        </dd>
                    </dl> @* [cite: 77] *@
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="">
            <div class="card">
                <div class="card-body">
                    @* [cite: 78] *@
                    <h5 class="card-title">Description</h5> @* [cite: 78] *@
                    <p class="card-text">@Html.Raw(MarkdownHelper.ToHtml(Model.Description))</p> @* [cite: 78] *@
                </div>
            </div>

            <ul class="nav nav-tabs" id="inventoryTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="items-tab" data-bs-toggle="tab" data-bs-target="#items" type="button" role="tab">
                        Items
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="discussion-tab" data-bs-toggle="tab" data-bs-target="#discussion" type="button" role="tab">
                        Discussion
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="statistics-tab" data-bs-toggle="tab" data-bs-target="#statistics" type="button" role="tab">
                        Statistics
                    </button>
                </li> 
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="items" role="tabpanel">
                    <div class="card">
                        <div class="card-body">
                            <div id="itemsContainer">
                                @* [cite: 83] *@
                                Loading...
                            </div>
                        </div> @* [cite: 84] *@
                    </div>
                </div>
                <div class="tab-pane fade" id="discussion" role="tabpanel">
                    <div class="card">
                        <div class="card-body">
                            @* [cite: 85] *@
                            <div id="discussionContainer">
                                Loading...
                            </div> @* [cite: 86] *@
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="statistics" role="tabpanel">
                    <div class="card">
                        @* [cite: 87] *@
                        <div class="card-body">
                            <div id="statisticsContainer">
                                Loading...
                            </div> @* [cite: 88] *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div> 
</div>

@section Scripts {
    <script src="~/js/Details.js" asp-append-version="true"></script>

    <script>
        initDetailsPage({
        inventoryId: '@Model.Id',
        canEdit: '@(ViewBag.CanEdit ? "true" : "false")',
        userId: '@ViewBag.UserId'
        });
    </script>
}

