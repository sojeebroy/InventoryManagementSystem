@model List<Inventory>
@{
    ViewData["Title"] = "Inventories";
}

<div class="container-main">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Inventories</h1>
        </div>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="col-md-4 text-end">
                <a href="/Inventories/Create" class="btn btn-primary">+ Create New Inventory</a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body empty-state">
                <h5 class="mb-3">No inventories found</h5>
                <p class="text-muted">
                    @if (string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <span>@(User.Identity?.IsAuthenticated ?? false ? "Create one to get started!" : "Login to create an inventory.")</span>
                    }
                    else
                    {
                        <span>Try adjusting your search terms.</span>
                    }
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="card mb-3" id="accessibleToolbar" style="display: none; background-color: #f0f7ff; border-left: 4px solid #0d6efd;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <span id="accessibleSelectedCount" style="font-weight: 600; color: #0d6efd;"></span>
                </div>
                <div class="btn-group gap-2" role="group">
                    <a href="#" class="btn btn-sm btn-info" id="accessibleViewBtn">👁️ View</a>
                </div>
            </div>
        </div>

        <div class="table-responsive-custom">
            <table class="table table-hover mb-0" id="accessibleTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 3%">
                            <input type="checkbox" id="accessibleSelectAllCheckbox" class="form-check-input" onchange="toggleSelectAll(this, 'accessible')" style="display: none;">
                        </th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Created</th>
                        <th>Visibility</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inventory in Model)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input accessible-checkbox" value="@inventory.Id" onchange="updateAccessibleToolbar()">
                            </td>
                            <td>
                                <strong>@inventory.Title</strong>
                                <br>
                                <small class="text-muted">@inventory.Description?.Substring(0, Math.Min(50, inventory.Description.Length))...</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@inventory.Category</span>
                            </td>
                            <td>
                                <small>@inventory.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </td>
                            <td>
                                @if (inventory.Visibility == Inventory_Management_System.Models.VisibilityType.Public)
                                {
                                    <span class="badge bg-success">Public</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Private</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="/Inventories/Details/@inventory.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=1&searchTerm=@ViewBag.SearchTerm">First</a>
                    </li>
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)&searchTerm=@ViewBag.SearchTerm">Previous</a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        if (i == ViewBag.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else if (i <= 3 || i >= ViewBag.TotalPages - 2 || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                        {
                            <li class="page-item">
                                <a class="page-link" href="?page=@i&searchTerm=@ViewBag.SearchTerm">@i</a>
                            </li>
                        }
                        else if (i == 4 || i == ViewBag.TotalPages - 3)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)&searchTerm=@ViewBag.SearchTerm">Next</a>
                    </li>
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@ViewBag.TotalPages&searchTerm=@ViewBag.SearchTerm">Last</a>
                    </li>
                </ul>
            </nav>

            <div class="alert alert-info mt-2">
                <strong>Total:</strong> @ViewBag.TotalCount inventories | 
                <strong>Page:</strong> @ViewBag.CurrentPage of @ViewBag.TotalPages | 
                <strong>Per Page:</strong> @ViewBag.PageSize
            </div>
        }
    }
</div>


                                    
<style>
    .form-check-input {
        cursor: pointer;
    }

    .gap-2 {
        gap: 0.5rem;
    }

    .btn-group {
        display: flex;
    }
</style>

<script>
  
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('owned-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.owned-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateOwnedToolbar();
        }
    });

    function updateAccessibleToolbar() {
        const checkboxes = document.querySelectorAll('.accessible-checkbox:checked');
        const toolbar = document.getElementById('accessibleToolbar');
        const selectedCount = document.getElementById('accessibleSelectedCount');

        if (checkboxes.length > 0) {
            toolbar.style.display = 'block';
            selectedCount.textContent = `1 inventory selected`;
            updateAccessibleActionButtons();
        } else {
            toolbar.style.display = 'none';
        }
    }

    function updateAccessibleActionButtons() {
        const checkbox = document.querySelector('.accessible-checkbox:checked');
        if (!checkbox) return;

        const inventoryId = checkbox.value;
        const viewBtn = document.getElementById('accessibleViewBtn');

        viewBtn.href = `/Inventories/Details/${inventoryId}`;
    }

    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('accessible-checkbox')) {
            if (e.target.checked) {
                const allCheckboxes = document.querySelectorAll('.accessible-checkbox');
                allCheckboxes.forEach(cb => {
                    if (cb !== e.target) {
                        cb.checked = false;
                    }
                });
            }
            updateAccessibleToolbar();
        }
    });
</script>
